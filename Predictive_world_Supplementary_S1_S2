    plt.ylabel("Global Cognition")
    plt.title("Parameter Sensitivity: K_BODY & K_ENERGY")
    plt.legend()
    plt.tight_layout()
    plt.savefig(os.path.join(FIG_DIR,"parameter_sensitivity.png"))
    plt.close()
    print("Parameter sensitivity figure saved")

    # ============================================================
    # Summary metrics
    # ============================================================

    summary_metrics = df[["Metastability","BrainHeartCoherence","ForwardModeling",
                          "EnergyStability","EnergyEfficiency","GlobalCognition"]].agg(['mean','std']).T
    summary_metrics['Mean±SD'] = summary_metrics['mean'].round(3).astype(str) + " ± " + summary_metrics['std'].round(3).astype(str)
    summary_metrics.to_csv(os.path.join(SAVE_DIR,"summary_metrics.csv"))
    print("Summary metrics table saved")
