    plt.close()
    pd.DataFrame(corr_results).T.to_csv(os.path.join(SAVE_DIR,"correlations_all_models.csv"))
    print("Correlations of all models vs cognition saved")

    # ============================================================
    # Mediation: BrainHeartCoherence → EnergyEfficiency → GlobalCognition
    # ============================================================

    mediation_results = bootstrap_mediation(
        X=df["BrainHeartCoherence"].values,
        M=df["EnergyEfficiency"].values,
        Y=df["GlobalCognition"].values,
        n_boot=1000,
        seed=SEED_GLOBAL
    )
    pd.DataFrame([mediation_results]).to_csv(os.path.join(SAVE_DIR,"mediation_results.csv"))
    print("Bootstrap mediation saved")

    # ============================================================
    # Parameter sensitivity visualization
    # ============================================================

    for Kb in sorted(df["K_BODY"].unique()):
        for Ke in sorted(df["K_ENERGY"].unique()):
            subset = df[(df["K_BODY"]==Kb) & (df["K_ENERGY"]==Ke)]
            plt.scatter(subset["BrainHeartCoherence"], subset["GlobalCognition"], alpha=0.3,
